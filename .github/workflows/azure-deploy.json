{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "webAppNames": {
            "type": "array",
            "defaultValue": [
                "craft-airtravel",
                "craft-airtravel-accomodations"
            ],
            "metadata": {
                "description": "The names of the web apps to create."
            }
        },
        "appServicePlanName": {
            "type": "string",
            "defaultValue": "craft-travel-sp",
            "metadata": {
                "description": "The name of the App Service plan."
            }
        },
        "location": {
            "type": "string",
            "defaultValue": "West US 2",
            "metadata": {
                "description": "The Azure region for the resources."
            }
        },
        "sku": {
            "type": "string",
            "defaultValue": "B1",
            "metadata": {
                "description": "The SKU for the App Service plan."
            }
        },
        "appConfigStoreName": {
            "type": "string",
            "defaultValue": "Craft-Travel-Config",
            "metadata": {
                "description": "The name of the App Configuration store."
            }
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.AppConfiguration/configurationStores",
            "apiVersion": "2023-03-01",
            "name": "[parameters('appConfigStoreName')]",
            "location": "[parameters('location')]",
            "sku": {
                "name": "standard"
            },
            "properties": {}
        },
        {
            "type": "Microsoft.AppConfiguration/configurationStores/keyValues",
            "apiVersion": "2023-03-01",
            "name": "[concat(parameters('appConfigStoreName'), '/stripepaymenturl')]",
            "dependsOn": [
                "[resourceId('Microsoft.AppConfiguration/configurationStores', parameters('appConfigStoreName'))]"
            ],
            "properties": {
                "value": "https://stripe.com/payment"
            }
        },
        {
            "type": "Microsoft.AppConfiguration/configurationStores/keyValues",
            "apiVersion": "2023-03-01",
            "name": "[concat(parameters('appConfigStoreName'), '/copilotchaturl')]",
            "dependsOn": [
                "[resourceId('Microsoft.AppConfiguration/configurationStores', parameters('appConfigStoreName'))]"
            ],
            "properties": {
                "value": "https://copilot.chat"
            }
        },
        {
            "type": "Microsoft.Web/serverfarms",
            "apiVersion": "2022-09-01",
            "name": "[parameters('appServicePlanName')]",
            "location": "[parameters('location')]",
            "sku": {
                "name": "[parameters('sku')]"
            },
            "properties": {
                "reserved": true
            }
        },
        {
            "copy": {
                "name": "appInsightsLoop",
                "count": "[length(parameters('webAppNames'))]"
            },
            "type": "Microsoft.Insights/components",
            "apiVersion": "2020-02-02",
            "name": "[concat(parameters('webAppNames')[copyIndex()], '-insights')]",
            "location": "[parameters('location')]",
            "kind": "web",
            "properties": {
                "Application_Type": "web"
            }
        },
        {
            "copy": {
                "name": "webAppLoop",
                "count": "[length(parameters('webAppNames'))]"
            },
            "type": "Microsoft.Web/sites",
            "apiVersion": "2022-09-01",
            "name": "[parameters('webAppNames')[copyIndex()]]",
            "location": "[parameters('location')]",
            "dependsOn": [
                "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
            ],
            "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
                "siteConfig": {
                    "netFrameworkVersion": "v10.0",
                    "healthCheckPath": "/health"
                }
            }
        }
    ],
    "outputs": {
        "webAppUrls": {
            "type": "array",
            "copy": {
                "count": "[length(parameters('webAppNames'))]",
                "input": "[concat('https://', parameters('webAppNames')[copyIndex()], '.azurewebsites.net')]"
            }
        },
        "appConfigEndpoint": {
            "type": "string",
            "value": "[reference(parameters('appConfigStoreName')).endpoint]"
        },
        "appInsightsConnectionStrings": {
            "type": "array",
            "copy": {
                "count": "[length(parameters('webAppNames'))]",
                "input": "[reference(resourceId('Microsoft.Insights/components', concat(parameters('webAppNames')[copyIndex()], '-insights'))).connectionString]"
            }
        }
    }
}
