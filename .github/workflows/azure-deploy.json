{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "webAppName": {
            "type": "string",
            "defaultValue": "craft-airtravel",
            "metadata": {
                "description": "The name of the web app to create."
            }
        },
        "appServicePlanName": {
            "type": "string",
            "defaultValue": "craft-travel-sp",
            "metadata": {
                "description": "The name of the App Service plan."
            }
        },
        "location": {
            "type": "string",
            "defaultValue": "West US 2",
            "metadata": {
                "description": "The Azure region for the resources."
            }
        },
        "sku": {
            "type": "string",
            "defaultValue": "B1",
            "metadata": {
                "description": "The SKU for the App Service plan."
            }
        },
        "appConfigStoreName": {
            "type": "string",
            "defaultValue": "Craft-Travel-Config",
            "metadata": {
                "description": "The name of the App Configuration store."
            }
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.AppConfiguration/configurationStores",
            "apiVersion": "2023-03-01",
            "name": "[parameters('appConfigStoreName')]",
            "location": "[parameters('location')]",
            "sku": {
                "name": "standard"
            },
            "properties": {}
        },
        {
            "type": "Microsoft.AppConfiguration/configurationStores/keyValues",
            "apiVersion": "2023-03-01",
            "name": "[concat(parameters('appConfigStoreName'), '/stripepaymenturl')]",
            "dependsOn": [
                "[resourceId('Microsoft.AppConfiguration/configurationStores', parameters('appConfigStoreName'))]"
            ],
            "properties": {
                "value": "https://stripe.com/payment"
            }
        },
        {
            "type": "Microsoft.AppConfiguration/configurationStores/keyValues",
            "apiVersion": "2023-03-01",
            "name": "[concat(parameters('appConfigStoreName'), '/copilotchaturl')]",
            "dependsOn": [
                "[resourceId('Microsoft.AppConfiguration/configurationStores', parameters('appConfigStoreName'))]"
            ],
            "properties": {
                "value": "https://copilot.chat"
            }
        },
        {
            "type": "Microsoft.Web/serverfarms",
            "apiVersion": "2022-09-01",
            "name": "[parameters('appServicePlanName')]",
            "location": "[parameters('location')]",
            "sku": {
                "name": "[parameters('sku')]"
            },
            "properties": {
                "reserved": true
            }
        },
        {
            "type": "Microsoft.Web/sites",
            "apiVersion": "2022-09-01",
            "name": "[parameters('webAppName')]",
            "location": "[parameters('location')]",
            "dependsOn": [
                "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
            ],
            "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
                "siteConfig": {
                    "netFrameworkVersion": "v10.0",
                    "healthCheckPath": "/health"
                }
            }
        }
    ],
    "outputs": {
        "webAppUrl": {
            "type": "string",
            "value": "[concat('https://', parameters('webAppName'), '.azurewebsites.net')]"
        }
    }
}
