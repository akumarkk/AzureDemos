{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "webApps": {
            "type": "array",
            "defaultValue": [
                {
                    "name": "craft-airtravel-accomodations",
                    "servicePlan": "craft-travel-accomodations-sp",
                    "netFrameworkVersion": "v8.0"
                },
                {
                    "name": "craft-airtravel-api",
                    "servicePlan": "craft-travel-api-sp",
                    "netFrameworkVersion": "v11.0"
                }
            ]
        },
        "location": {
            "type": "string",
            "defaultValue": "East US",
            "metadata": {
                "description": "The Azure region for the resources."
            }
        },
        "sku": {
            "type": "string",
            "defaultValue": "F1",
            "metadata": {
                "description": "The SKU for the App Service plan."
            }
        }
    },
    "variables": {},
    "resources": [
        {
            "copy": {
                "name": "webAppLoop",
                "count": "[length(parameters('webApps'))]"
            },
            "type": "Microsoft.Web/serverfarms",
            "apiVersion": "2022-09-01",
            "name": "[parameters('webApps')[copyIndex()].servicePlan]",
            "location": "[parameters('location')]",
            "sku": {
                "name": "[parameters('sku')]"
            },
            "properties": {
                "reserved": true
            }
        },
        {
            "copy": {
                "name": "webAppLoop",
                "count": "[length(parameters('webApps'))]"
            },
            "type": "Microsoft.Web/sites",
            "apiVersion": "2022-09-01",
            "name": "[parameters('webApps')[copyIndex()].name]",
            "location": "[parameters('location')]",
            "dependsOn": [
                "[resourceId('Microsoft.Web/serverfarms', parameters('webApps')[copyIndex()].servicePlan)]"
            ],
            "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('webApps')[copyIndex()].servicePlan)]",
                "siteConfig": {
                    "netFrameworkVersion": "[parameters('webApps')[copyIndex()].netFrameworkVersion]"
                }
            }
        }
    ],
    "outputs": {
        "webAppUrl": {
            "type": "string",
            "value": "[concat('https://', parameters('webAppName'), '.azurewebsites.net')]"
        }
    }
}
